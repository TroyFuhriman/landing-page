{
  "routes": [
    {
      "route": "/",
      "headers": {
        "Content-Type": "text/html; charset=utf-8",
        "Cache-Control": "no-cache, no-store, must-revalidate"
      }
    },
    {
      "route": "/*.html",
      "headers": {
        "Content-Type": "text/html; charset=utf-8",
        "Cache-Control": "no-cache, no-store, must-revalidate"
      }
    },
    {
      "route": "/*.css",
      "headers": {
        "Cache-Control": "public, max-age=604800, stale-while-revalidate=86400"
      }
    },
    {
      "route": "/*.js",
      "headers": {
        "Cache-Control": "public, max-age=604800, stale-while-revalidate=86400"
      }
    },
    {
      "route": "/*.png",
      "headers": {
        "Cache-Control": "public, max-age=604800, immutable"
      }
    },
    {
      "route": "/*.webp",
      "headers": {
        "Cache-Control": "public, max-age=604800, immutable"
      }
    }
  ]
}
